# AI Services
GEMINI_API_KEY=your-gemini-api-key-here
LLM_KEY=your-nvidia-api-key-here

# Google Cloud TTS
GOOGLE_APPLICATION_CREDENTIALS=gcloud_key.json

# External APIs
OPENWEATHER_API_KEY=your-openweather-api-key-here
# data.gov.in mandi price API key (https://data.gov.in/ → register for an API key)
DATA_GOV_API_KEY=your-data-gov-api-key-here

# CORS — comma-separated allowed origins. "*" (default) suits local dev and
# native apps. Set explicit origins in production to enable credentialed CORS,
# e.g. CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=*

# LangSmith (optional)
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=sakhi-ai
LANGSMITH_TRACING=false
